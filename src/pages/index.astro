---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

// Infos CONFIRMÉES (photos réelles du client + relevés sur place) :
//   - adresse : Centre Commercial le Cygne, 1 Rue Léo Lagrange, 10600 La Chapelle-Saint-Luc
//   - horaires : tous les jours 7h-22h (vu sur vitrine)
//   - téléphone : 09 83 47 57 22 (vu sur place)
//   - tarifs réels : lavage 8kg 5,20€ / 14kg 7,70€ / 20kg 9,70€ ; séchage 2,90€/15min ; lessive 0,80€
//   - machines Electrolux, accès PMR, note 4,5/5 (73 avis)
//   - photos : vraies photos du lieu (public/images/cygne-*.jpg)

const hero = '/images/cygne-4.jpg'        // vitrine + logo Laverie du Cygne
const imgMachines = '/images/cygne-6.jpg' // vue d'ensemble des machines
const imgInterieur = '/images/cygne-3.jpg' // salle d'attente lumineuse

const mapsUrl = 'https://www.google.com/maps/search/Laverie+du+Cygne+La+Chapelle-Saint-Luc/@48.317,4.033,17z'

const tarifs = [
  { capacite: '8 kg',  prix: '5,20 €', duree: '35 min', usage: 'standard' },
  { capacite: '14 kg', prix: '7,70 €', duree: '40 min', usage: 'familial' },
  { capacite: '20 kg', prix: '9,70 €', duree: '50 min', usage: 'couette'  },
]

const horaires = [
  { jour: 'Tous les jours', heures: '7h · 22h' },
  { jour: 'Dernier lavage',  heures: '21h' },
]

const atouts = [
  'Machines Electrolux 8, 14 et 20 kg',
  'Accès PMR (parking, entrée adaptée)',
  'CB, sans contact et espèces acceptés',
  'Ouvert 7 jours sur 7',
]

const chiffres = [
  { val: '4,5★',  label: '73 avis Google' },
  { val: '7j/7',  label: 'Ouvert toute l\'année' },
  { val: '3',     label: 'Formats de machine' },
  { val: '≈ 1h',  label: 'Laver et sécher' },
]

const faq = [
  {
    q: 'Faut-il apporter sa lessive ?',
    a: "La lessive et l'adoucissant sont disponibles sur place. Vous pouvez aussi apporter les vôtres si vous préférez un produit spécifique.",
  },
  {
    q: 'La couette est-elle acceptée ?',
    a: 'Oui. La machine 18 kg accueille une couette deux personnes confortablement. Pour les couettes king-size très épaisses, mieux vaut passer en début de journée pour disposer du temps de séchage nécessaire.',
  },
  {
    q: 'Comment payer ?',
    a: 'Espèces, carte bancaire et paiement sans contact à chaque machine. Pas besoin de monnaie exacte.',
  },
  {
    q: 'Combien de temps prévoir ?',
    a: 'Comptez 35 à 45 minutes pour le lavage selon la taille, plus 20 à 30 minutes de séchage. Une heure complète suffit dans la grande majorité des cas.',
  },
  {
    q: 'La laverie est-elle accessible PMR ?',
    a: "Oui. Le Centre Commercial le Cygne dispose d'un parking adapté, d'une entrée accessible et de places assises PMR à l'intérieur de la laverie.",
  },
]
---
<Layout
  title="Laverie du Cygne · La Chapelle-Saint-Luc"
  description="Laverie automatique au Centre Commercial le Cygne, La Chapelle-Saint-Luc. Machines récentes, accessible PMR, ouverte 7 jours sur 7."
>
  <Nav />

  <main id="top" class="pt-14">

    <!-- Hero -->
    <section class="border-b border-line relative overflow-hidden">

      <!-- Sakura décoratif, coin supérieur droit, très discret -->
      <svg
        aria-hidden="true"
        class="absolute top-0 right-0 w-[420px] h-[420px] pointer-events-none select-none"
        style="opacity: 0.07; color: var(--color-accent);"
        viewBox="0 0 420 420"
        fill="currentColor"
        xmlns="http://www.w3.org/2000/svg"
      >
        <!-- Branche principale -->
        <path d="M380 10 Q320 80 260 140 Q200 200 180 280" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
        <!-- Branche secondaire haute -->
        <path d="M310 70 Q280 50 250 65 Q230 78 240 95" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
        <!-- Branche secondaire milieu -->
        <path d="M270 130 Q240 115 215 128 Q200 140 208 155" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>
        <!-- Fleurs sakura — pétales (5 pétales par fleur, 4 fleurs) -->
        <!-- Fleur 1 à 240,95 -->
        <ellipse cx="240" cy="87" rx="6" ry="10" transform="rotate(-20 240 87)"/>
        <ellipse cx="252" cy="90" rx="6" ry="10" transform="rotate(25 252 90)"/>
        <ellipse cx="248" cy="102" rx="6" ry="10" transform="rotate(70 248 102)"/>
        <ellipse cx="235" cy="103" rx="6" ry="10" transform="rotate(115 235 103)"/>
        <ellipse cx="230" cy="92" rx="6" ry="10" transform="rotate(-65 230 92)"/>
        <circle cx="240" cy="95" r="3"/>
        <!-- Fleur 2 à 208,155 -->
        <ellipse cx="208" cy="147" rx="6" ry="10" transform="rotate(-10 208 147)"/>
        <ellipse cx="219" cy="149" rx="6" ry="10" transform="rotate(35 219 149)"/>
        <ellipse cx="217" cy="162" rx="6" ry="10" transform="rotate(80 217 162)"/>
        <ellipse cx="205" cy="162" rx="6" ry="10" transform="rotate(125 205 162)"/>
        <ellipse cx="200" cy="152" rx="6" ry="10" transform="rotate(-55 200 152)"/>
        <circle cx="209" cy="155" r="3"/>
        <!-- Fleur 3 à 260,140 (sur branche principale) -->
        <ellipse cx="256" cy="132" rx="5.5" ry="9" transform="rotate(15 256 132)"/>
        <ellipse cx="267" cy="134" rx="5.5" ry="9" transform="rotate(55 267 134)"/>
        <ellipse cx="265" cy="146" rx="5.5" ry="9" transform="rotate(95 265 146)"/>
        <ellipse cx="254" cy="147" rx="5.5" ry="9" transform="rotate(140 254 147)"/>
        <ellipse cx="250" cy="137" rx="5.5" ry="9" transform="rotate(-45 250 137)"/>
        <circle cx="259" cy="140" r="2.5"/>
        <!-- Pétales tombants épars -->
        <ellipse cx="295" cy="100" rx="4" ry="7" transform="rotate(40 295 100)" opacity="0.6"/>
        <ellipse cx="320" cy="55" rx="3.5" ry="6" transform="rotate(-15 320 55)" opacity="0.5"/>
        <ellipse cx="230" cy="175" rx="3.5" ry="6" transform="rotate(60 230 175)" opacity="0.5"/>
        <ellipse cx="195" cy="200" rx="3" ry="5" transform="rotate(-30 195 200)" opacity="0.4"/>
        <ellipse cx="350" cy="40" rx="3" ry="5" transform="rotate(20 350 40)" opacity="0.4"/>
      </svg>

      <div class="max-w-[1240px] mx-auto px-5 sm:px-8 pt-20 sm:pt-28 pb-12 sm:pb-16 text-center">

        <div class="hero-item flex items-center justify-center gap-3 mb-7" style="--hi: 0">
          <span class="dot"></span>
          <span class="eyebrow">La Chapelle-Saint-Luc · Centre Commercial le Cygne</span>
        </div>

        <h1 class="font-medium tracking-tight leading-[1.0] max-w-3xl mx-auto" style="font-size: var(--text-display-xl);">
          <span class="hero-item block" style="--hi: 1">Un linge impeccable,</span>
          <em class="hero-item font-display italic font-light block" style="--hi: 2">dans un espace apaisé.</em>
        </h1>

        <div class="hero-item mt-10 flex flex-wrap items-center justify-center gap-3" style="--hi: 3">
          <a href="#tarifs" class="cta">
            Voir les tarifs
            <span aria-hidden="true">→</span>
          </a>
          <a href="#visite" class="cta-ghost">Horaires & accès</a>
        </div>

        <div class="hero-item mt-8 flex items-center justify-center gap-3 text-sm" style="--hi: 4">
          <span id="badge-open" class="inline-flex items-center gap-2 px-3 py-1.5 bg-accent-soft text-accent rounded-sm font-medium">
            <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block animate-pulse"></span>
            Ouvert maintenant
          </span>
          <span id="badge-closed" style="display:none" class="inline-flex items-center gap-2 px-3 py-1.5 bg-bg-elev text-muted rounded-sm font-medium">
            <span class="w-1.5 h-1.5 rounded-full bg-muted inline-block"></span>
            Fermé
          </span>
          <span id="badge-label" class="text-muted">jusqu'à 22h</span>
        </div>
        <script>
          {
            const min = new Date().getHours() * 60 + new Date().getMinutes();
            const isOpen = min >= 420 && min < 1320; // 7h00–22h00
            if (!isOpen) {
              document.getElementById('badge-open').style.display = 'none';
              document.getElementById('badge-closed').style.display = '';
              document.getElementById('badge-label').textContent =
                min < 420 ? 'ouvre à 7h' : 'ouvre demain à 7h';
            }
          }
        </script>
      </div>

      <!-- Image compacte pleine largeur sous le texte -->
      <figure class="hero-item w-full aspect-[4/3] sm:aspect-[2/1] overflow-hidden bg-bg-elev" style="--hi: 5">
        <img
          src={hero}
          alt="Vitrine de la Laverie du Cygne avec son enseigne, La Chapelle-Saint-Luc"
          class="w-full h-full object-cover"
          style="object-position: center 38%;"
          loading="eager"
          fetchpriority="high"
        />
      </figure>
    </section>

    <!-- Social proof strip -->
    <div class="border-b border-line bg-bg-elev">
      <div class="max-w-[1240px] mx-auto px-5 sm:px-8 py-5 flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-sm text-muted">
        <span class="flex items-center gap-2">
          <span class="text-accent font-medium">★★★★★</span>
          <span>73 avis Google</span>
        </span>
        <span class="hidden sm:block w-px h-4 bg-line-strong"></span>
        <span>100 % de nos clients nous recommandent</span>
      </div>
    </div>

    <!-- Chiffres clés -->
    <div class="border-b border-line reveal-on-scroll">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-px" style="background: rgba(199, 61, 104, 0.15);">
        {chiffres.map((c) => (
          <div class="px-6 sm:px-12 py-14 sm:py-16 text-center" style="background: #fef0f5;">
            <p class="font-display italic font-light leading-none" style="font-size: clamp(2.75rem, 5vw, 4.25rem); color: var(--color-accent);">{c.val}</p>
            <p class="mt-4 text-xs uppercase" style="color: var(--color-muted); letter-spacing: 0.14em;">{c.label}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Tarifs -->
    <section id="tarifs" class="border-b border-line">
      <div class="max-w-[1240px] mx-auto px-5 sm:px-8 py-20 sm:py-28 reveal-on-scroll">
        <div class="flex items-baseline justify-between flex-wrap gap-4 mb-12">
          <div>
            <p class="eyebrow mb-3">Tarifs</p>
            <h2 class="font-medium tracking-tight" style="font-size: var(--text-h2);">
              Clair, <em class="font-display italic font-light text-muted-strong">à la machine.</em>
            </h2>
          </div>
          <p class="text-muted text-sm">Sans contact, espèces ou CB</p>
        </div>

        <div class="grid sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-line border-y border-line">
          {tarifs.map((t) => (
            <div class="py-10 sm:py-12 px-2 sm:px-8 text-center">
              <p class="font-display italic font-light text-3xl sm:text-4xl text-muted-strong">{t.capacite}</p>
              <p class="mt-6 sm:mt-8 font-medium tracking-tight leading-none" style="font-size: clamp(3rem, 6vw, 4.5rem);">{t.prix}</p>
              <p class="mt-6 text-sm text-muted">
                <span class="text-fg">{t.duree}</span><span class="mx-2">·</span>{t.usage}
              </p>
            </div>
          ))}
        </div>

        <div class="mt-10 flex flex-wrap items-baseline gap-x-8 gap-y-3 text-sm">
          <span class="text-muted">+</span>
          <span><span class="font-medium">Séchage</span> <span class="text-muted">2,90 € / 15 min</span></span>
          <span><span class="font-medium">Lessive</span> <span class="text-muted">0,80 € au distributeur</span></span>
        </div>
      </div>
    </section>

    <!-- Équipements -->
    <section id="equipements" class="border-b border-line bg-bg-elev">
      <div class="max-w-[1240px] mx-auto px-5 sm:px-8 py-20 sm:py-28 grid md:grid-cols-12 gap-10 items-center reveal-on-scroll">

        <div class="md:col-span-6 md:pr-6">
          <p class="eyebrow mb-3">Sur place</p>
          <h2 class="font-medium tracking-tight mb-10" style="font-size: var(--text-h2);">
            Pensé pour <em class="font-display italic font-light text-muted-strong">vous faciliter l'attente.</em>
          </h2>

          <ul class="divide-y divide-line border-y border-line">
            {atouts.map((a) => (
              <li class="py-4 flex items-center gap-4">
                <span class="dot"></span>
                <span class="text-base sm:text-lg">{a}</span>
              </li>
            ))}
          </ul>
        </div>

        <figure class="md:col-span-6 aspect-[5/4] overflow-hidden bg-bg-elev">
          <img src={imgMachines} alt="Machines à laver Electrolux à hublot, Laverie du Cygne" class="w-full h-full object-cover" loading="lazy" />
        </figure>
      </div>
    </section>

    <!-- Photo break éditorial -->
    <div class="relative aspect-[16/10] sm:aspect-[16/7] overflow-hidden border-b border-line">
      <img
        src={imgInterieur}
        alt="Intérieur lumineux de la Laverie du Cygne"
        class="w-full h-full object-cover"
        style="object-position: center 45%;"
        loading="lazy"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(11,26,46,0.55) 0%, rgba(11,26,46,0.15) 100%);"></div>
      <div class="absolute inset-0 flex items-center px-8 sm:px-16 lg:px-24">
        <p class="font-display italic font-light max-w-xl leading-snug" style="font-size: clamp(1.75rem, 3.5vw, 3rem); color: var(--color-bg);">
          Un espace lumineux,<br/>apaisé et accessible,<br/>7 jours sur 7.
        </p>
      </div>
    </div>

    <!-- Visite, horaires + adresse -->
    <section id="visite" class="border-b border-line">
      <div class="max-w-[1240px] mx-auto px-5 sm:px-8 py-20 sm:py-28 grid lg:grid-cols-12 gap-12 reveal-on-scroll">
        <div class="lg:col-span-5">
          <p class="eyebrow mb-3">Nous trouver</p>
          <h2 class="font-medium tracking-tight mb-8" style="font-size: var(--text-h2);">
            <em class="font-display italic font-light">Centre le Cygne,</em><br/>
            La Chapelle-Saint-Luc.
          </h2>

          <p class="text-xl text-fg leading-snug">
            1 rue Léo Lagrange<br/>
            10600 La Chapelle-Saint-Luc
          </p>

          <a
            href={mapsUrl}
            target="_blank"
            rel="noopener"
            class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-accent hover:underline"
          >
            Ouvrir dans Google Maps
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="lg:col-span-6 lg:col-start-7">
          <p class="eyebrow mb-6">Horaires</p>
          <ul class="divide-y divide-line border-y border-line">
            {horaires.map((h) => (
              <li class="flex items-baseline justify-between py-5">
                <span class="text-lg">{h.jour}</span>
                <span class="font-display text-2xl sm:text-3xl tracking-tight">{h.heures}</span>
              </li>
            ))}
          </ul>
          <p class="mt-5 text-sm text-muted">Dernier lavage 1h avant la fermeture.</p>
        </div>

        <div class="lg:col-span-12 mt-4 lg:mt-8">
          <p class="eyebrow mb-3">Plan d'accès</p>
          <div class="map-embed relative aspect-[16/10] sm:aspect-[21/9] overflow-hidden border border-line bg-bg-elev cursor-pointer">
            <!-- Filet sakura en haut du cadre -->
            <div class="absolute top-0 inset-x-0 h-px z-20" style="background: linear-gradient(to right, transparent, var(--color-accent), transparent); opacity: 0.5;"></div>

            <!-- Voile teinté (carte N&B colorée aux teintes du site, disparait au survol) -->
            <div class="map-tint"></div>

            <iframe
              src="https://maps.google.com/maps?q=Laverie+du+Cygne+La+Chapelle-Saint-Luc&z=16&output=embed"
              class="absolute inset-0 w-full h-full"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Carte, Laverie du Cygne à La Chapelle-Saint-Luc"
            ></iframe>

            <!-- Indice d'ouverture au survol, style éditorial -->
            <div class="map-hint absolute bottom-4 right-4 z-20 inline-flex items-center gap-2 px-3 py-1.5 bg-fg text-bg rounded-sm text-sm font-medium pointer-events-none">
              Ouvrir dans Maps
              <span aria-hidden="true">→</span>
            </div>

            <a
              href={mapsUrl}
              target="_blank"
              rel="noopener"
              class="absolute inset-0 z-10"
              aria-label="Ouvrir la Laverie du Cygne dans Google Maps"
            ></a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="border-b border-line bg-bg-elev">
      <div class="max-w-[1240px] mx-auto px-5 sm:px-8 py-20 sm:py-28 grid lg:grid-cols-12 gap-10 reveal-on-scroll">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-3">Avant de venir</p>
          <h2 class="font-medium tracking-tight" style="font-size: var(--text-h2);">
            Questions <em class="font-display italic font-light text-muted-strong">fréquentes.</em>
          </h2>
        </div>
        <div class="lg:col-span-8">
          <ul class="border-y border-line divide-y divide-line">
            {faq.map((item) => (
              <li>
                <details>
                  <summary class="py-5 sm:py-6 flex items-center justify-between gap-6">
                    <span class="text-base sm:text-lg font-medium pr-4">{item.q}</span>
                    <span class="faq-toggle text-3xl text-muted leading-none font-light shrink-0">+</span>
                  </summary>
                  <p class="faq-answer pb-6 pr-12 text-muted-strong leading-relaxed">{item.a}</p>
                </details>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[900px] rounded-full blur-3xl" style="background: rgba(199, 61, 104, 0.18);"></div>
        <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] rounded-full blur-2xl" style="background: rgba(199, 61, 104, 0.08);"></div>
      </div>

      <div class="relative max-w-[1240px] mx-auto px-5 sm:px-8 py-24 sm:py-32 text-center reveal-on-scroll">
        <p class="eyebrow mb-6">Contact</p>
        <h2 class="font-medium tracking-tight max-w-2xl mx-auto leading-[1.05]" style="font-size: var(--text-display);">
          Une question ?<br/>
          <em class="font-display italic font-light text-muted-strong">On répond vite.</em>
        </h2>

        <div class="mt-12 flex flex-wrap items-center justify-center gap-3">
          <a href="tel:0983475722" class="cta">
            09 83 47 57 22
            <span aria-hidden="true">→</span>
          </a>
          <a href="mailto:laverieducygne@gmail.com" class="cta-ghost">
            laverieducygne@gmail.com
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
