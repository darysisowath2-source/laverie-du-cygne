---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---
<Layout title="Page introuvable · Laverie du Cygne" description="Cette page n'existe pas.">
  <Nav />
  <main id="top" class="pt-20">
    <section class="min-h-[60vh] flex items-center">
      <div class="max-w-[1240px] mx-auto px-5 sm:px-8 py-24 text-center">
        <p class="eyebrow mb-4">Erreur 404</p>
        <h1 class="font-medium tracking-tight leading-[1.05] mb-6" style="font-size: var(--text-display);">
          Cette page <em class="font-display italic font-light text-muted-strong">a pris l'eau.</em>
        </h1>
        <p class="text-muted mb-10 max-w-md mx-auto">La page que vous cherchez n'existe pas ou a été déplacée.</p>
        <a href="/" class="cta">Retour à l'accueil <span aria-hidden="true">→</span></a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
