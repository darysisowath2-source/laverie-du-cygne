---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Laverie du Cygne · La Chapelle-Saint-Luc',
  description = "Laverie automatique au Centre Commercial le Cygne, La Chapelle-Saint-Luc. Machines récentes, accessible PMR, ouverte 7 jours sur 7.",
} = Astro.props
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f3f8fd" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,400;1,300;1,400&family=Inter+Tight:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content="https://laverie-du-cygne.pages.dev/images/cygne-4.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="800" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://laverie-du-cygne.pages.dev/images/cygne-4.jpg" />
    <link rel="canonical" href={"https://laverie-du-cygne.pages.dev" + Astro.url.pathname} />

    <!-- SEO local : donnees structurees (Google rich results, "laverie pres de moi") -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "DryCleaningOrLaundry",
      "name": "Laverie du Cygne",
      "image": "https://laverie-du-cygne.pages.dev/images/cygne-4.jpg",
      "url": "https://laverie-du-cygne.pages.dev",
      "telephone": "+33983475722",
      "priceRange": "€",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1 rue Léo Lagrange, Centre commercial le Cygne",
        "addressLocality": "La Chapelle-Saint-Luc",
        "postalCode": "10600",
        "addressCountry": "FR"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 48.317, "longitude": 4.033 },
      "openingHoursSpecification": [{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "07:00", "closes": "22:00"
      }],
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.5", "reviewCount": "73" }
    })} />
  </head>
  <body class="bg-bg text-fg antialiased">
    <slot />

    <script>
      // Apparition au scroll, vanilla JS, ~600 octets gzippés
      const targets = document.querySelectorAll('.reveal-on-scroll');
      if ('IntersectionObserver' in window && targets.length) {
        const io = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
        targets.forEach((el) => io.observe(el));
      } else {
        targets.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <script>
      import Lenis from 'lenis'
      const lenis = new Lenis({
        duration: 1.1,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      })

      // Câbler tous les liens d'ancre sur Lenis pour un scroll fluide
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          e.preventDefault()
          const id = (anchor as HTMLAnchorElement).getAttribute('href')
          if (id) lenis.scrollTo(id, { offset: -72 })
        })
      })

      function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf) }
      requestAnimationFrame(raf)
    </script>
  </body>
</html>
